# Required - Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Optional - model id (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---------- Local development ----------
# In local dev (`npm run dev`), Next.js and the WebSocket server run on
# separate ports. Set WS_PORT for the server side and NEXT_PUBLIC_WS_PORT
# (or NEXT_PUBLIC_WS_URL) so the browser knows where to connect.
WS_PORT=3001
NEXT_PUBLIC_WS_PORT=3001

# ---------- Production (Railway / single-service) ----------
# `npm start` runs the custom server (server.ts) which serves Next.js and
# WebSocket on the same PORT. Leave WS_PORT, NEXT_PUBLIC_WS_PORT, and
# NEXT_PUBLIC_WS_URL unset on Railway - the browser will connect to the
# same origin automatically.

# Optional - full browser WebSocket URL override. Only needed when the WS
# server is on a completely separate host.
# NEXT_PUBLIC_WS_URL=wss://my-ws-host.example.com
