# Required — Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Optional — model id (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional — WebSocket server port (default 3001)
WS_PORT=3001

# Optional — browser WebSocket URL (overrides port-based default)
# NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Optional — browser WebSocket port (used if NEXT_PUBLIC_WS_URL is not set; default 3001)
# NEXT_PUBLIC_WS_PORT=3001
