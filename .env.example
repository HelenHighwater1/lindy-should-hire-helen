# Required — Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Optional — model id (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional — WebSocket server port (default 3001).
# In local dev, this is the port the standalone WebSocket server listens on.
# In production (e.g. Railway), the same value can be used so the app and WS
# server run inside a single service and the browser connects to this port.
WS_PORT=3001

# Optional — disable in-process WebSocket server in environments where you
# run the WS server separately. For Railway, leave this unset so
# src/instrumentation.ts starts the WebSocket server in the Node runtime.
# DISABLE_IN_PROCESS_WS=1

# Optional — full browser WebSocket URL (overrides host:port). Leave unset
# when running a single service (Next.js + WS) so the client builds the URL
# from window.location and NEXT_PUBLIC_WS_PORT.
# NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Optional — browser WebSocket port (used if NEXT_PUBLIC_WS_URL is not set;
# default 3001). In production on Railway with a single service, set this to
# the same value as WS_PORT so the browser connects to ws(s)://<host>:WS_PORT.
# NEXT_PUBLIC_WS_PORT=3001
