# Required — Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Optional — model id (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional — WebSocket server port (default 3001). On Render, omit WS_PORT so the
# server uses PORT (injected by the platform).
WS_PORT=3001

# When deploying Next on Render without in-process WebSocket, set to 1 so
# instrumentation does not bind a second port on the web service.
# DISABLE_IN_PROCESS_WS=1

# Optional — full browser WebSocket URL (overrides host:port). Required when the WS
# worker is a separate host (e.g. Render lindy-ws). Use wss://
# NEXT_PUBLIC_WS_URL=wss://lindy-ws.onrender.com
# NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Optional — browser WebSocket port (used if NEXT_PUBLIC_WS_URL is not set; default 3001)
# NEXT_PUBLIC_WS_PORT=3001
